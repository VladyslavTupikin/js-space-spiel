class Point {
    -x : int
    -y : int
    --
    .. General ..
    -Point()
    +toString() : String
    .. Getters / Setters ..
    +getX() : int
    +gety() : int
    +setX() : void
    +setY() : void
}

class Style <<CSS styles>> {
    -pathToStyle : String
    --
    .. General ..
    +toString() : String
    +loadStyle() : boolean
    .. Getters / Setters ..
    +getPathToStyle() : String
    +setPathToStyle() : void
}

class EnemyMap {
    -enemyMap: int[][]
    --
    -EnemyMap()
    .. General ..
    + toString() : String
    + initEnemyMap() : boolean
}

class Map  <<singleton>> {
    -instance : Map
    -width : int
    -height : int
    -style : Style
    --
    -Map()
    -loadMapStyle() : boolean
    .. General ..
    +toString() : String
    .. Getters / Setters ..
    +getInstance() : Map
    +setWidth() : void
    +getWidth() : int
    +setHeight() : void
    +getHeight() : int
}

@enduml
