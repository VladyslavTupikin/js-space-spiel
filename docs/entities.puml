abstract class Ship <<BaseClass>> {
    #id: int
    #width: int
    #height: int
    #center: Point
    #health: int
    # {abstract} style: Style
    --
    #Ship()
    .. General ..
    +toString() : String
    .. Movement ..
    +move()
    .. Getters / Setters ..
    +getID() : int
    +getWidth() : int
    +getHeight() : int
    +getCenter() : Point
    +getHealth() : int
    +setHealth() : void
}

class EnemyShip extends Ship {
    - listeners: List<OnMoveListener>
    --
    -EnemyShip()
    -loadEnemyStyle() : boolean
    .. General ..
    + <<override>> toString() : String
    .. Movement ..
    + <<override>> moveRight() : void
    + <<override>> moveLeft() : void
    .. Event Listener ..
    + addMoveListener(l: OnMoveListener): void
    + removeMoveListener(l: OnMoveListener): void
}

class PlayerShip extends Ship {
    - listeners: List<OnMoveListener>
    --
    -PlayerShip()
    -loadPlayerStyle() : boolean
    .. General ..
    + <<override>> toString() : String
    .. Event Listener ..
    + addMoveListener(l: OnMoveListener): void
    + removeMoveListener(l: OnMoveListener): void
}

abstract class Gun <<BaseClass>> {
    #style : Style
    #ammo : int
    --
    #Gun()
    .. General ..
    + {abstract} toString() : String
    + {abstract} loadGunStyle() : boolean
    .. Shooting ..
    + {abstract} shootProjectile() : void
    .. Getters / Setters ..
    +getAmmo() : int
    +setAmmo() : int
}

class PistolGun extends Gun {
    --
    -PistolGun()
    -loadPistolGunStyle() : boolean
    .. General ..
    + <<override>> toString() : String
    .. Shiitung ..
    + <<override>> shootProjectile() : void
}

@enduml
